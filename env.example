# ============================
# Discord Donation Bot - ENV
# ============================

# Token บอท Discord (จาก Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord User ID เจ้าของบอท (รับ DM แจ้งเตือนทุกครั้งที่มีโดเนท)
OWNER_ID=123456789012345678

# PromptPay: เบอร์โทรศัพท์ หรือ เลขประจำตัว 13 หลัก
PROMPTPAY_NUMBER=0812345678

# TrueMoney Wallet: เบอร์โทรที่ผูกบัญชี
TRUEMONEY_NUMBER=0812345678

# ชื่อบัญชี TrueMoney (แสดงให้ผู้โดเนทยืนยันก่อนโอน)
TRUEMONEY_NAME=ชื่อ นามสกุล
